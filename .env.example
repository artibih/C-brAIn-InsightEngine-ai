OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Default LLM Configuration
DEFAULT_LLM_PROVIDER=openai  # openai, anthropic
DEFAULT_MODEL=gpt-4.1
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-resource.services.ai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_ONLINE=your_online_deployment_name
AZURE_OPENAI_DEPLOYMENT_BACKGROUND=your_background_deployment_name
AZURE_OPENAI_DEPLOYMENT_GRAPH=your_graph_deployment_name
AZURE_OPENAI_DEPLOYMENT_EVAL=your_eval_deployment_name

# Switchable LLM deployments. Store API keys in local/deployment secrets.
# Optional Azure AI Foundry deployments can reuse AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_API_KEY.

# Vector Database (Weaviate)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=optional_api_key

# Graph Database (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=4

# Metrics Thresholds
MAX_RESPONSE_TIME_SIMPLE=5  # seconds
MAX_RESPONSE_TIME_COMPLEX=3600  # 1 hour
CITATION_HALLUCINATION_THRESHOLD=1e-8
CITATION_IRRELEVANCE_THRESHOLD=1e-3

# Code Execution
CODE_EXECUTION_TIMEOUT=300  # seconds
MAX_CODE_EXECUTION_MEMORY=2048  # MB

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Environment
ENVIRONMENT=development  # development, staging, production
